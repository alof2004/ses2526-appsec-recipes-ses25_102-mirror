   <section id=\"appointments\" className={styles.panel}>\n      <div className={styles.panelHeading}>\n        <h2>Appointments</h2>\n        <p>Manage appointment records and filter directly through the backend.</p>\n      </div>\n\n      <div className={styles.panelActions}>\n        <button\n          type=\"button\"\n          className={`${styles.btn} ${styles.btnPrimary}`}\n          onClick={onCreate}\n          disabled={busyAction}\n        >\n          New Appointment\n        </button>\n      </div>\n\n      <form className={styles.filterForm} onSubmit={onApplyFilters}>\n        <label>\n          Patient Name\n          <input\n            name=\"patientName\"\n            value={appointmentFilters.patientName}\n            onChange={(event) =>\n              setAppointmentFilters((current) => ({\n                ...current,\n                patientName: event.target.value,\n              }))\n            }\n            placeholder=\"Filter by patient name\"\n          />\n        </label>\n        <label>\n          Date\n          <input\n            type=\"date\"\n            name=\"date\"\n            value={appointmentFilters.date}\n            onChange={(event) =>\n              setAppointmentFilters((current) => ({\n                ...current,\n                date: event.target.value,\n              }))\n            }\n          />\n        </label>\n        <label>\n          Status\n          <select\n            name=\"status\"\n            value={appointmentFilters.status}\n            onChange={(event) =>\n              setAppointmentFilters((current) => ({\n                ...current,\n                status: event.target.value,\n              }))\n            }\n          >\n            <option value=\"\">All</option>\n            {STATUSES.map((status) => (\n              <option key={status} value={status}>\n                {toStatusLabel(status)}\n              </option>\n            ))}\n          </select>\n        </label>\n        <label>\n          Specialty\n          <select\n            name=\"specialty\"\n            value={appointmentFilters.specialty}\n            onChange={(event) =>\n              setAppointmentFilters((current) => ({\n                ...current,\n                specialty: event.target.value,\n              }))\n            }\n          >\n            <option value=\"\">All</option>\n            {SPECIALTIES.map((specialty) => (\n              <option key={specialty} value={specialty}>\n                {specialty}\n              </option>\n            ))}\n          </select>\n        </label>\n        <div className={styles.buttonRow}>\n          <button type=\"submit\" className={`${styles.btn} ${styles.btnPrimary}`} disabled={busyAction}>\n            Apply Filters\n          </button>\n          <button\n            type=\"button\"\n            className={`${styles.btn} ${styles.btnGhost}`}\n            onClick={onClearFilters}\n            disabled={busyAction}\n          >\n            Reset\n          </button>\n        </div>\n      </form>\n\n      <div className={styles.tableWrap}>\n        <table>\n          <thead>\n            <tr>\n              <th>Date and Time</th>\n              <th>Patient</th>\n              <th>Specialty</th>\n              <th>Status</th>\n              <th>Actions</th>\n            </tr>\n          </thead>\n          <tbody>\n            {appointmentRows.length === 0 && (\n              <tr>\n                <td colSpan=\"5\">No appointments found for current filters.</td>\n              </tr>\n            )}\n            {appointmentRows.map((appointment) => {\n              const statusClassName = STATUS_CLASS_BY_VALUE[appointment.statusClass]\n              const statusClass = statusClassName ? styles[statusClassName] : ''\n\n              return (\n                <tr key={appointment.id}>\n                  <td>{toDateTimeDisplay(appointment.dateTime)}</td>\n                  <td>{appointment.patientName}</td>\n                  <td>{appointment.specialty}</td>\n                  <td>\n                    <span className={`${styles.statusPill} ${statusClass}`.trim()}>\n                      {appointment.statusLabel}\n                    </span>\n                  </td>\n                  <td className={styles.actionsCell}>\n                    <button\n                      type=\"button\"\n                      className={`${styles.btn} ${styles.btnGhost}`}\n                      onClick={() => onStartEdit(appointment)}\n                      disabled={busyAction}\n                    >\n                      Edit\n                    </button>\n                    <button\n                      type=\"button\"\n                      className={`${styles.btn} ${styles.btnDanger}`}\n                      onClick={() => onDelete(appointment)}\n                      disabled={busyAction}\n                    >\n                      Delete\n                    </button>\n                  </td>\n                </tr>\n              )\n            })}\n          </tbody>\n        </table>\n      </div>\n    </section>\n  )\n}\n\nexport default AppointmentsPanel\n","usedDeprecatedRules":[]},{"filePath":"/home/runner/work/softwate-baseline-ses25_102-mirror/softwate-baseline-ses25_102-mirror/src/frontend/src/components/ConfirmActionModal.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/runner/work/softwate-baseline-ses25_102-mirror/softwate-baseline-ses25_102-mirror/src/frontend/src/components/FeedbackBanner.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/runner/work/softwate-baseline-ses25_102-mirror/softwate-baseline-ses25_102-mirror/src/frontend/src/components/HeroHeader.jsx","messages":[],"suppressedMessages":[],"